{
    "manifest_version": 3,
    "name": "SIPLABA Kota Tegal 2026",
    "description": "Integrasi SIPD Penatausahaan - Simlaba Kota Tegal Tahun 2026",
    "author" :"HERI PRIHANTO @ Pepedan Village",
    "version": "1.4",
    "action": {
      "default_icon": {
        "16": "/laba.png",
        "32": "/laba.png",
        "48": "/laba.png",
        "128": "/laba.png"
      }
    },
    "icons": {
      "16": "/laba.png",
      "32": "/laba.png",
      "48": "/laba.png",
      "128": "/laba.png"
    },
    "permissions": ["scripting", "activeTab"],
    "host_permissions": [
      "https://sipd.kemendagri.go.id/*"
    ],
    
    "content_scripts": [
      {
        "matches": ["https://sipd.kemendagri.go.id/penatausahaan*"],
        "js": ["sipd.js"],
        "run_at": "document_idle"
      }
    ]
  }
  