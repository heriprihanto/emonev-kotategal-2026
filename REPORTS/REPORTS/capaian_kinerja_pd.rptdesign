            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT 
  o.*,
  COALESCE(t.v2,0) as isverif
FROM
  public.ta_opd o
  LEFT JOIN public.ta_laporan_eval_renja t ON (o.id_pd = t.id_pd)
  WHERE o.id_pd=? and t.tw=? and o.is_pd=1]]></xml-property>
