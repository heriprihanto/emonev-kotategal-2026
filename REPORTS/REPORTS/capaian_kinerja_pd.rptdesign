            <xml-property name="queryText"><![CDATA[SELECT 
  p.kd_tujuan,p.kd_sasaran,
  concat(p.kd_tujuan,'.',p.kd_sasaran) as kdtujuansasaran,
  o.id_pd,
  o.kode as kode_sub_pd,
  o.nama_pd,
  s.sasaran,
  r.*,
  xr.rkeu_tw1,xr.rkeu_tw2,xr.rkeu_tw3,xr.rkeu_tw4,
  0::numeric as rkeu_total,0::numeric as rkeu_rpj,0::numeric as rkeu_persen,
  ri.lvl,ri.nomor,ri.tolok_ukur,ri.satuan,ri.idjenis,ri.kategori,ri.target,ri.ck4 as cap_lalu,
  ri.target_akhir, ri.ck_tw1, ri.ck_tw2, ri.ck_tw3, ri.ck_tw4,ri.tg_tw2,ri.tg_tw3,ri.tg_tw4,ri.ck_tw1_ps,ri.ck_tw2_ps,ri.ck_tw3_ps,ri.ck_tw4_ps,ri.ck_tw1_psx,ri.ck_tw2_psx,ri.ck_tw3_psx,ri.ck_tw4_psx,
  ri.psn,ri.psn_rpj
FROM
  public.ta_renja_subkegiatan r
  INNER JOIN public.ta_opd o ON (r.id_sub_pd = o.id_sub_pd)
  INNER JOIN public.renstra_program  p ON (r.kode_program = p.kode_program) AND (o.id_pd = p.id_pd)
  INNER JOIN public.renstra_sasaran s ON (p.id_pd = s.id_sub_pd)
  AND (p.kd_tujuan = s.kd_tujuan)
  AND (p.kd_sasaran = s.kd_sasaran)
  INNER JOIN public.ta_renja_indikator ri ON (r.idsubkegiatan=ri.id_parent)
  LEFT JOIN (SELECT 
  r.idsubkegiatan,
  SUM (CASE WHEN r.bulan <4 THEN r.realisasi ELSE 0 END) as rkeu_tw1,
  SUM (CASE WHEN r.bulan <7 THEN r.realisasi ELSE 0 END) as rkeu_tw2,
  SUM (CASE WHEN r.bulan <10 THEN r.realisasi ELSE 0 END) as rkeu_tw3,
  SUM (CASE WHEN r.bulan <13 THEN r.realisasi ELSE 0 END) as rkeu_tw4
FROM
  public.ta_renja_subkegiatan_realisasi r
  GROUP BY r.idsubkegiatan)xr ON (r.idsubkegiatan=xr.idsubkegiatan)
    where r.tahun=? and o.id_pd=?
    order by s.kd_tujuan, s.kd_sasaran, r.kode_program,r.kode_kegiatan,r.kode_sub_kegiatan;
    ]]></xml-property>
