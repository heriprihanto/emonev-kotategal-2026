            <xml-property name="queryText"><![CDATA[select r.*,
concat(r.t1_kode,r.t2_kode) as t2,
concat(r.t1_kode,r.t2_kode,r.t3_kode) as t3,
concat(r.t1_kode,r.t2_kode,r.t3_kode,r.t4_kode) as t4,
concat(r.t1_kode,r.t2_kode,r.t3_kode,r.t4_kode,r.t5_kode) as t5 
FROM dak_detail_rincian r where r.tahun=? and r.kat_dak=1 and r.bulan=?;]]></xml-property>
