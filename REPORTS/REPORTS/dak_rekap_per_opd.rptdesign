                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT x.* FROM
(SELECT 
  p.kode,
  p.nama_pd,
  d.id_sub_pd,
  d.kat_dak,
  SUM(d.pagu) as pagu,
  0::numeric as pendamping,
  SUM(d.real_k) as real_k,
  (SUM(d.real_fisik * d.pagu)/SUM(d.pagu)) as real_fisik
FROM
  public.dak_detail_rincian d
  INNER JOIN public.ta_opd p ON (d.id_sub_pd = p.id_sub_pd)
  WHERE d.tahun=? and d.bulan=?
  GROUP BY
  p.kode,
  p.nama_pd,
  d.id_sub_pd,
  d.kat_dak)x ORDER BY x.kode
  ]]></xml-property>
