            <xml-property name="queryText"><![CDATA[SELECT 
0 as kd_tujuan,0 as kd_sasaran,
'' as kd_sas_gab,
'' as sasaran,
  k.id_subkegiatan,
  k.id_kegiatan,
  k.id_program,
  k.tahun,
  k.id_pd,
  k.id_sub_pd,
  k.id_bidang,
  k.kd_urusana,
  k.kd_bidanga,
  k.kd_unita,
  k.kd_suba,
  k.kd_suba as kd_sub,
  k.kd_suba::text as kd_sub_unit,
  k.kd_bidang_gab,k.kd_bidang_gab as kd_bid_gab,
  k.kd_unit_gab,
  k.kd_sub_gab,
  k.nm_bidang_gab,
  k.nm_unit_gab,
  k.nm_sub_unit_gab,
  k.nm_sub_unit_gab as nm_sub_unit,
  k.kd_urusan,
  k.kd_bidang,
  k.kd_program,
  k.kd_program as kd_prog,
  k.kd_kegiatan,
  k.kd_kegiatan as kd_keg,
  k.kd_sub_kegiatan,
  k.kd_gab_urusan,
  k.kd_gab_bidang,
  k.kd_gab_prog,k.kd_gab_prog as kd_prog_gab,
  k.kd_gab_keg,k.kd_gab_keg as kd_keg_gab,
  k.kd_gab_sub_keg,
  k.nm_urusan,
  k.nm_bidang,
  k.nm_program,
  k.nm_kegiatan,
  k.nm_program as ket_program,
  k.nm_kegiatan as ket_kegiatan,
  k.nm_sub_kegiatan,
  k.lokasi,
  k.nm_sumber,
  k.id_ppk,
  k.id_pptk,
  k.id_personel,
  k.pagu_akhir_renstra,
  k.pagu_renstra,k.pagu_renstra as anggaran_renstra,
  k.pagu_renja,
  k.capaian_lalu as capaian_renstra,
  a.total as anggaran,
  i.kd_tahap,
  i.kd_indikator,
  i.no_id,
  i.tolak_ukur,
  i.target,
  i.target as target_angka,
  i.satuan,
  i.satuan as target_uraian,
  i.target_renja,
  i.target_renstra,
  i.target_akhir_renstra,
  i.capaian_lalu as capaian_renstra_n1,
  i.tw1,
  i.tw2,
  i.tw3,
  i.tw4,
  i.tipe,
  i.jenis,
  i.ket,
  i.masalah,
  i.upaya,
  COALESCE(rk.r1,0) as rtw1,COALESCE(rk.r2,0) as rtw2,COALESCE(rk.r3,0) as rtw3,COALESCE(rk.r4,0) as rtw4
FROM
  public.ta_subkegiatan k
  INNER JOIN public.ta_indikator_subkegiatan i ON (k.id_subkegiatan = i.id_subkegiatan)
  INNER JOIN public.ta_subkegiatan_anggaran a ON (k.id_subkegiatan = a.id_subkegiatan)
  LEFT JOIN
  (SELECT r.id_subkegiatan,
              SUM(CASE WHEN r.bulan < 4 THEN r.realisasi END) AS r1,
              SUM(CASE WHEN (r.bulan BETWEEN 4 AND 6) THEN r.realisasi END) AS r2,
              SUM(CASE WHEN (r.bulan BETWEEN 7 AND 9) THEN r.realisasi END) AS r3,
              SUM(CASE WHEN r.bulan >= 10 THEN r.realisasi END) AS r4
       FROM ta_subkegiatan_realisasi r
       GROUP BY r.id_subkegiatan
  ) rk ON k.id_subkegiatan=rk.id_subkegiatan
WHERE k.tahun=? and k.kd_gab_bidang=? and k.nm_sub_unit_gab not like '%Sekolah%' and k.nm_sub_unit_gab not like '%Puskesmas%' and k.nm_sub_unit_gab not like '%Klinik Paru%';]]></xml-property>
