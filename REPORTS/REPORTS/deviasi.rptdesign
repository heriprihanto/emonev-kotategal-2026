                    <expression name="expression" type="javascript">if (params["pbulan"].value ==1) {&#13;
	dataSetRow["jan_f"]&#13;
} else if (params["pbulan"].value ==2) {&#13;
	dataSetRow["feb_f"]&#13;
} else if (params["pbulan"].value ==3) {&#13;
	dataSetRow["mar_f"]&#13;
} &#13;
else if (params["pbulan"].value ==4) {&#13;
	dataSetRow["apr_f"]&#13;
} &#13;
else if (params["pbulan"].value ==5) {&#13;
	dataSetRow["mei_f"]&#13;
}&#13;
else if (params["pbulan"].value ==6) {&#13;
