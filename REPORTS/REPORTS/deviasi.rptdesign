                    <property name="dataType">decimal</property>
                </structure>
                <structure>
                    <property name="name">target_persen_keu</property>
                    <expression name="expression" type="javascript">if (params["pbulan"].value ==1) {&#13;
	dataSetRow["jan"]&#13;
} else if (params["pbulan"].value ==2) {&#13;
	dataSetRow["feb"]&#13;
} else if (params["pbulan"].value ==3) {&#13;
	dataSetRow["mar"]&#13;
} &#13;
else if (params["pbulan"].value ==4) {&#13;
	dataSetRow["apr"]&#13;
} &#13;
else if (params["pbulan"].value ==5) {&#13;
	dataSetRow["mei"]&#13;
}&#13;
else if (params["pbulan"].value ==6) {&#13;
	dataSetRow["jun"]&#13;
}&#13;
else if (params["pbulan"].value ==7) {&#13;
