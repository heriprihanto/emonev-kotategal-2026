                    <property name="nativeName">nov_f</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">2</property>
                </structure>
                <structure>
                    <property name="position">32</property>
                    <property name="name">des_f</property>
                    <property name="nativeName">des_f</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">2</property>
                </structure>
                <structure>
                    <property name="position">33</property>
                    <property name="name">real_keu</property>
                    <property name="nativeName">real_keu</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">2</property>
                </structure>
                <structure>
                    <property name="position">34</property>
                    <property name="name">r_fisik</property>
                    <property name="nativeName">r_fisik</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">2</property>
                </structure>
                <structure>
                    <property name="position">35</property>
                    <property name="name">persen_real_keu</property>
                    <property name="nativeName">persen_real_keu</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">2</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT x.*,((x.real_keu/x.anggaran)*100) as persen_real_keu FROM
(SELECT 
  pd.id_sub_pd,
  pd.kd_urusan,
  pd.kd_bidang,
  pd.kd_unit,
  pd.kd_sub,
  pd.kode_sub_pd,
  pd.nm_sub_pd,
  an.anggaran,
  p0.jan,
  p0.feb,
  p0.mar,
  p0.apr,
  p0.mei,
  p0.jun,
  p0.jul,
  p0.agu,
  p0.sep,
  p0.okt,
  p0.nov,
  p0.des,
  p0.jan_f,
  p0.feb_f,
  p0.mar_f,
  p0.apr_f,
  p0.mei_f,
  p0.jun_f,
  p0.jul_f,
  p0.agu_f,
  p0.sep_f,
  p0.okt_f,
  p0.nov_f,
  p0.des_f,
 COALESCE (r.real_keu,0) as real_keu,
 COALESCE(f.r_fisik,0) as r_fisik
FROM
public.ref_sub_pd pd
INNER JOIN (SELECT k.id_sub_pd,SUM(a.total) as anggaran FROM public.ta_subkegiatan k INNER JOIN public.ta_subkegiatan_anggaran a ON (k.id_subkegiatan = a.id_subkegiatan) GROUP BY k.id_sub_pd) an
ON (pd.id_sub_pd=an.id_sub_pd)
INNER JOIN
(SELECT 
  p.id_sub_pd,
  AVG(p.jan) as jan,
  AVG(p.feb) as feb,
  AVG(p.mar) as mar,
  AVG(p.apr) as apr,
  AVG(p.mei) as mei,
  AVG(p.jun) as jun,
  AVG(p.jul) as jul,
  AVG(p.agu) as agu,
  AVG(p.sep) as sep,
  AVG(p.okt) as okt,
  AVG(p.nov) as nov,
  AVG(p.des) as des,
  AVG(p.jan_f) as jan_f,
  AVG(p.feb_f) as feb_f,
  AVG(p.mar_f) as mar_f,
  AVG(p.apr_f) as apr_f,
  AVG(p.mei_f) as mei_f,
  AVG(p.jun_f) as jun_f,
  AVG(p.jul_f) as jul_f,
  AVG(p.agu_f) as agu_f,
  AVG(p.sep_f) as sep_f,
  AVG(p.okt_f) as okt_f,
  AVG(p.nov_f) as nov_f,
  AVG(p.des_f) as des_f FROM public.ta_pekerjaan p GROUP BY p.id_sub_pd
)p0 ON (pd.id_sub_pd = p0.id_sub_pd)
LEFT JOIN (SELECT 
  rr.id_sub_pd,
  sum(rr.realisasi) as real_keu
FROM
  public.ta_subkegiatan_realisasi rr where rr.bulan <=?
GROUP BY
  rr.id_sub_pd) r
ON (pd.id_sub_pd = r.id_sub_pd) 
LEFT JOIN 
(
SELECT p1.id_sub_pd,avg(p1.fisik) as r_fisik FROM
(SELECT 
  p.id_sub_pd,
  p.id_pekerjaan,
  max(p.fisik) as fisik
FROM
  public.ta_pekerjaan_realisasi p
  WHERE p.bulan <= ?
  GROUP BY p.id_sub_pd,
  p.id_pekerjaan) p1 GROUP BY p1.id_sub_pd
) f 
ON (pd.id_sub_pd = f.id_sub_pd)
) x;
]]></xml-property>
        </oda-data-set>
    </data-sets>
