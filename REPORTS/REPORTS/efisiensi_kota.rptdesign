                    <property name="nativeDataType">2</property>
                </structure>
                <structure>
                    <property name="position">31</property>
                    <property name="name">sastra</property>
                    <property name="nativeName">sastra</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">32</property>
                    <property name="name">kd_tujsas</property>
                    <property name="nativeName">kd_tujsas</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">33</property>
                    <property name="name">kd_sas</property>
                    <property name="nativeName">kd_sas</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[(SELECT 
  i.id,
  i.lvl,
  i.tahun,
  i.kode,
  i.nomor,
  i.tolok_ukur,
  i.ket,
  i.satuan,
  i.target,
  i.target_akhir,
  i.tg_tw1,
  i.tg_tw2,
  i.tg_tw3,
  i.tg_tw4,
  i.ck_tw1,
  i.ck_tw2,
  i.ck_tw3,
  i.ck_tw4,
  i.ck_tw1_ps,
  i.ck_tw2_ps,
  i.ck_tw3_ps,
  i.ck_tw4_ps,
  i.ms1,
  i.ms2,
  i.ms3,
  i.ms4,
  i.ck_tw1_psx,
  i.ck_tw2_psx,
  i.ck_tw3_psx,
  i.ck_tw4_psx,
  t.tujuan as sastra,  
  concat(t.kd_tujuan,'.') as kd_tujsas,
  concat(i.lvl,'.',t.kd_tujuan) as kd_sas
FROM
  public.ta_renja_indikator i
  INNER JOIN public.rpjmd_tujuan t ON (i.id_parent = t.id) WHERE 'IKU Kota' = ANY (i.tags) ORDER BY t.kd_tujuan ASC,i.nomor)
UNION ALL
(SELECT 
  i.id,
  i.lvl,
  i.tahun,
  i.kode,
  i.nomor,
  i.tolok_ukur,
  i.ket,
  i.satuan,
  i.target,
  i.target_akhir,
  i.tg_tw1,
  i.tg_tw2,
  i.tg_tw3,
  i.tg_tw4,
  i.ck_tw1,
  i.ck_tw2,
  i.ck_tw3,
  i.ck_tw4,
  i.ck_tw1_ps,
  i.ck_tw2_ps,
  i.ck_tw3_ps,
  i.ck_tw4_ps,
  i.ms1,
  i.ms2,
  i.ms3,
  i.ms4,
  i.ck_tw1_psx,
  i.ck_tw2_psx,
  i.ck_tw3_psx,
  i.ck_tw4_psx,
  t.sasaran as sastra,
  concat(t.kd_tujuan,'.',t.kd_sasaran) as kd_tujsas,
  concat(i.lvl,'.',t.kd_tujuan,'.',t.kd_sasaran) as kd_sas
FROM
  public.ta_renja_indikator i
  INNER JOIN public.rpjmd_sasaran t ON (i.id_parent = t.id) WHERE 'IKU Kota' = ANY (i.tags) ORDER BY t.kd_tujuan ASC,i.nomor)
]]></xml-property>
