            <xml-property name="queryText"><![CDATA[SELECT 
  r.kode_urusan,
  r.nama_urusan,
  r.kode_bidang_urusan,
  r.nama_bidang_urusan,
  r.nama_bidang_urusan_2,
  r.program,
  r.opd,
  rr.indikator,
  rr.t2023,
  rr.satuan,
  sk.prog 
FROM
  public.ref_rpjmd_program_2 r
  INNER JOIN public.ref_rpjmd rr ON (r.program = rr.program)
  LEFT JOIN (SELECT DISTINCT k.nama_program as prog FROM  public.data_sub_kegiatan k) sk ON (rr.program = sk.prog)
]]></xml-property>
        </oda-data-set>
