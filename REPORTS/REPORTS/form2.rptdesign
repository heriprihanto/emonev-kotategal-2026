                    <property name="nativeName">jml_program</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">8</property>
                    <property name="name">jml_keg</property>
                    <property name="nativeName">jml_keg</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">9</property>
                    <property name="name">jml_subkeg</property>
                    <property name="nativeName">jml_subkeg</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">10</property>
                    <property name="name">jml_angg</property>
                    <property name="nativeName">jml_angg</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">2</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT bu.opd,bu.kode_urusan,  bu.kode_bidang_urusan,bu.nama_urusan,bu.nama_bidang_urusan,bu.nama_bidang_urusan_2,
jp.jml_program,jk.jml_keg ,js.jml_subkeg,ja.jml_angg
FROM ref_bidang_urusan bu
INNER JOIN
(SELECT 
  sk.kode_bidang_urusan2,
  count(DISTINCT sk.nama_program) AS jml_program
FROM
  public.data_sub_kegiatan sk
GROUP BY
  sk.kode_bidang_urusan2) jp ON (bu.kode_bidang_urusan=jp.kode_bidang_urusan2) 
INNER JOIN
(SELECT 
  sk.kode_bidang_urusan2,
  count(DISTINCT sk.nama_giat_nama_giat) AS jml_keg
FROM
  public.data_sub_kegiatan sk
GROUP BY
  sk.kode_bidang_urusan2) jk ON (bu.kode_bidang_urusan=jk.kode_bidang_urusan2)  
INNER JOIN
(SELECT 
  sk.kode_bidang_urusan2,
  count(sk.nama_sub_giat_nama_sub_giat) AS jml_subkeg
FROM
  public.data_sub_kegiatan sk
GROUP BY
  sk.kode_bidang_urusan2) js ON (bu.kode_bidang_urusan=js.kode_bidang_urusan2)
INNER JOIN
(SELECT 
  sk.kode_bidang_urusan2,
  sum(sk.nama_sub_giat_rincian) AS jml_angg
FROM
  public.data_sub_kegiatan sk
GROUP BY
  sk.kode_bidang_urusan2) ja ON (bu.kode_bidang_urusan=ja.kode_bidang_urusan2);]]></xml-property>
        </oda-data-set>
