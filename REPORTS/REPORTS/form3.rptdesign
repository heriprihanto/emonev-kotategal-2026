            <xml-property name="queryText"><![CDATA[SELECT 
  h.hasilteks,
  h.satuanhasil,
  h.targethasil,
  h.targethasilteks,
  h.idkegiatan,
  count(*) as x
FROM
  public.data_hasil h
  where h.idkegiatan=?
  GROUP BY
  h.hasilteks,
  h.satuanhasil,
  h.targethasil,
  h.targethasilteks,
  h.idkegiatan;]]></xml-property>
