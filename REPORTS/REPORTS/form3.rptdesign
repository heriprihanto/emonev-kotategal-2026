            <xml-property name="queryText"><![CDATA[SELECT 
  bu.kode_urusan,
  bu.nama_urusan,
  bu.kode_bidang_urusan,
  bu.nama_bidang_urusan,
  k.kode_skpd,
  k.nama_skpd,
  k.kode_sub_skpd,
  k.nama_sub_skpd,
  k.id_program,
  k.kode_program,
  k.nama_program,
  k.id_giat,
  k.kode_giat,
  k.nama_giat_kode_bl,
  k.nama_giat_nama_giat,
  k.kode_sub_giat,
  k.nama_sub_giat_kode_bl,
  k.nama_sub_giat_kode_sbl,
  k.nama_sub_giat_nama_sub_giat,
  k.nama_sub_giat_pagu,
  k.nama_sub_giat_rincian,
  k.pagu,
  k.idprogram,
  k.idkegiatan,
  k.idsubkegiatan,
  i.idoutputbl,
  i.outputteks,
  i.targetoutput,
  i.satuanoutput
FROM
  public.ref_bidang_urusan bu
  INNER JOIN public.data_sub_kegiatan k ON (bu.kode_bidang_urusan = k.kode_bidang_urusan2)
  LEFT JOIN public.data_subkegiatan_indikator i ON (k.idsubkegiatan = i.idsubkegiatan)
]]></xml-property>
