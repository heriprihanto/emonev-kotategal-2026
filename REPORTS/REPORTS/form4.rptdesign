            <xml-property name="queryText"><![CDATA[SELECT 
  sk.id_unit,
  sk.nama_program,
  sk.nama_giat_nama_giat,
  sk.nama_sub_giat_nama_sub_giat,
  bu.kode_urusan,
  bu.kode_bidang_urusan,
  bu.nama_urusan,
  bu.nama_bidang_urusan,
  pp.kode_pn,
  pp.pn,
  SUM(sk.nama_sub_giat_rincian) as pagu
FROM
  public.data_sub_kegiatan sk
  INNER JOIN public.ref_bidang_urusan bu ON (sk.kode_bidang_urusan2 = bu.kode_bidang_urusan)
  INNER JOIN public.ref_pn pp ON (ringkas_text(sk.nama_program) = ringkas_text(pp.program))
  WHERE sk.id_unit=?
  GROUP BY
  sk.id_unit,
  sk.nama_program,
  sk.nama_giat_nama_giat,
  sk.nama_sub_giat_nama_sub_giat,
  bu.kode_urusan,
  bu.kode_bidang_urusan,
  bu.nama_urusan,
  bu.nama_bidang_urusan,
  pp.kode_pn,
  pp.pn
  
]]></xml-property>
