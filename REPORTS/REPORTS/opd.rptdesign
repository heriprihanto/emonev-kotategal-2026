            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT 
    s.kode_sub_skpd AS kode_opd,
    s.nama_sub_skpd AS opd,
    sum(case WHEN s.id_jadwal=1 THEN s.nama_sub_giat_rincian ELSE 0 END) AS anggaran,
    sum(case WHEN s.id_jadwal=22072022 THEN s.nama_sub_giat_rincian ELSE 0 END) AS kua,
    0::numeric as apbd
   FROM data_sub_kegiatan s
  GROUP BY s.kode_sub_skpd, s.nama_sub_skpd
  ORDER BY s.kode_sub_skpd;]]></xml-property>
        </oda-data-set>
    </data-sets>
