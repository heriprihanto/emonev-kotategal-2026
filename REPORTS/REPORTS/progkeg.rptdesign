            <xml-property name="queryText"><![CDATA[SELECT 
  p.kode_urusan,
  p.nama_urusan,
  p.kode_bidang_urusan,
  p.nama_bidang_urusan,
  p.kode_program,
  p.program,
  p.kode_giat,
  p.kegiatan
FROM
  public.data_progkeg_2 p
  WHERE p.program !='PROGRAM PENUNJANG URUSAN PEMERINTAHAN DAERAH KABUPATEN/KOTA'
UNION ALL
SELECT 
'x' as kode_urusan,
'Non Urusan' as nama_urusan,
'x.xx' as kode_bidang_urusan,
'Non Bidang'  as nama_bidang_urusan,
'x.xx' as kode_program,
k.program,k.kode_giat,k.kegiatan
FROM public.data_progkeg_2 k WHERE k.program='PROGRAM PENUNJANG URUSAN PEMERINTAHAN DAERAH KABUPATEN/KOTA']]></xml-property>
        </oda-data-set>
    </data-sets>
