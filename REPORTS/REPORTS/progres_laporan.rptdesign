                <structure>
                    <property name="name">jml_isi</property>
                    <expression name="expression" type="javascript">if (params["ptw"].value==1) {&#13;
dataSetRow["ptw1"]&#13;
} else if (params["ptw"].value==2) {&#13;
dataSetRow["ptw2"]&#13;
} else if (params["ptw"].value==3) {&#13;
dataSetRow["ptw3"]&#13;
} else if (params["ptw"].value==4) {&#13;
dataSetRow["ptw4"]&#13;
}</expression>
                    <property name="dataType">decimal</property>
                    <property name="allowExport">true</property>
                </structure>
                <structure>
                    <property name="name">ps_k</property>
                    <expression name="expression" type="javascript">(row["jml_isi"]/row["jml_ip"])*100</expression>
                    <property name="dataType">decimal</property>
                    <property name="allowExport">true</property>
                </structure>
            </list-property>
