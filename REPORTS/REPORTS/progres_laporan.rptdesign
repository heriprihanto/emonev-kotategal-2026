            <xml-property name="queryText"><![CDATA[SELECT pd.kode ,pd.nama_pd,
xp.jml_ip,xp.ptw1,xp.ptw2,xp.ptw3,xp.ptw4 FROM public.ta_opd pd

INNER JOIN
(SELECT ip.id_sub_pd,
 count(ip.tolok_ukur) as jml_ip,
SUM((CASE WHEN ip.ck_tw1 ISNULL THEN 0 ELSE 1 END)) as ptw1,
SUM((CASE WHEN ip.ck_tw2 ISNULL THEN 0 ELSE 1 END)) as ptw2,
SUM((CASE WHEN ip.ck_tw3 ISNULL THEN 0 ELSE 1 END)) as ptw3,
SUM((CASE WHEN ip.ck_tw4 ISNULL THEN 0 ELSE 1 END)) as ptw4
 FROM  public.ta_renja_indikator ip
GROUP BY ip.id_sub_pd) xp 
ON (pd.id_sub_pd=xp.id_sub_pd)
order by pd.kode asc]]></xml-property>
