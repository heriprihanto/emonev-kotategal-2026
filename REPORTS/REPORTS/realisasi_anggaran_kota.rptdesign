            <xml-property name="queryText"><![CDATA[SELECT k.kode_bidang_urusan,b.bidang_urusan_alias,  k.kode_program,k.nm_program,
sum(k.anggaran) as anggaran,
sum(x.rtw1) as rtw1,
sum(x.rtw2) as rtw2,
sum(x.rtw3) as rtw3,
sum(x.rtw4) as rtw4 
FROM ta_renja_subkegiatan k LEFT JOIN 
(SELECT 
  idsubkegiatan,
  sum(case WHEN bulan < 4 then realisasi else 0 end) as rtw1,
  sum(case WHEN bulan between 4 and 6 then realisasi else 0 end) as rtw2,
  sum(case WHEN bulan between 7 and 9 then realisasi else 0 end) as rtw3,
  sum(case WHEN bulan between 10 and 12 then realisasi else 0 end) as rtw4
FROM
  ta_renja_subkegiatan_realisasi where tahun=2025 GROUP BY idsubkegiatan )x
ON (k.idsubkegiatan = x.idsubkegiatan) 
INNER JOIN ref_bidang_urusan b ON (k.kode_bidang_urusan = b.kode_bidang_urusan)
GROUP BY k.kode_bidang_urusan,b.bidang_urusan_alias,k.kode_program,k.nm_program
ORDER BY kode_bidang_urusan,kode_program]]></xml-property>
