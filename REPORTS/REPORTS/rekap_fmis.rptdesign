            <xml-property name="queryText"><![CDATA[SELECT 
  p.kode_sub_pd,
  p.nm_sub_pd,
  rr.jan,rr.feb,rr.mar,rr.apr,rr.mei,rr.jun,rr.jul,rr.agu,rr.sep,rr.okt,rr.nov,rr.des
FROM
  public.ref_sub_pd p
  LEFT JOIN 
  (SELECT r.id_sub_pd,
  	sum(
                CASE
                    WHEN r.bulan = 1 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS jan,
            sum(
                CASE
                    WHEN r.bulan = 2 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS feb,
            sum(
                CASE
                    WHEN r.bulan = 3 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS mar,
            sum(
                CASE
                    WHEN r.bulan = 4 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS apr,
            sum(
                CASE
                    WHEN r.bulan = 5 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS mei,
            sum(
                CASE
                    WHEN r.bulan = 6 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS jun,
            sum(
                CASE
                    WHEN r.bulan = 7 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS jul,
            sum(
                CASE
                    WHEN r.bulan = 8 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS agu,
            sum(
                CASE
                    WHEN r.bulan = 9 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS sep,
            sum(
                CASE
                    WHEN r.bulan = 10 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS okt,
            sum(
                CASE
                    WHEN r.bulan = 11 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS nov,
            sum(
                CASE
                    WHEN r.bulan = 12 THEN r.realisasi_total
                    ELSE 0::numeric
                END) AS des
    FROM public.ta_subkegiatan_realisasi r GROUP BY r.id_sub_pd)rr ON (p.id_sub_pd = rr.id_sub_pd)
    ORDER BY p.kode_sub_pd;]]></xml-property>
