            <expression name="valueExpr">var months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];&#13;
var myDays = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jum&amp;#39;at', 'Sabtu'];&#13;
var date = new Date();&#13;
var day = date.getDate();&#13;
var month = date.getMonth();&#13;
var thisDay = date.getDay(),thisDay = myDays[thisDay];&#13;
var yy = date.getYear();&#13;
var year = (yy &lt; 1000) ? yy + 1900 : yy;&#13;
&#13;
thisDay + ', ' + day + ' ' + months[month] + ' ' + year+ ' '+date.getHours() +':'+date.getMinutes();</expression>
