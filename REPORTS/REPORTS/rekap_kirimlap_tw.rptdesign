            <xml-property name="queryText"><![CDATA[SELECT o.kode,o.nama_pd, x.*  FROM ta_opd o
LEFT JOIN 
(SELECT id_pd,
max(CASE WHEN tw = 1 THEN tgl2  ELSE NULL::date::timestamp   END) AS xtw1,
max(CASE WHEN tw = 2 THEN tgl2  ELSE NULL::date::timestamp   END) AS xtw2,
max(CASE WHEN tw = 3 THEN tgl2  ELSE NULL::date::timestamp   END) AS xtw3,
max(CASE WHEN tw = 4 THEN tgl2  ELSE NULL::date::timestamp   END) AS xtw4
FROM ta_laporan_eval_renja GROUP BY id_pd) x  ON (o.id_pd=x.id_pd) WHERE o.is_pd=1 ORDER BY o.kode]]></xml-property>
