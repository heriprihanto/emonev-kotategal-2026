            <xml-property name="queryText"><![CDATA[SELECT 
  c.idunikindikator,
  c.idprogram,
  c.satuancapaian,
  c.targetcapaianteks,
  c.capaianteks,
  c.targetcapaian,
  count(*) as d
FROM
  public.data_capaian_program c  where c.idprogram=?
  GROUP BY
  c.idunikindikator,
  c.idprogram,
  c.satuancapaian,
  c.targetcapaianteks,
  c.capaianteks,
  c.targetcapaian;]]></xml-property>
