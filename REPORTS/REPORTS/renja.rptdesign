            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT 
  k.id,
  k.id_jadwal,
  k.id_daerah,
  k.tahun,
  k.id_unit,
  k.id_skpd,
  k.id_urusan,
  k.kode_urusan,
  k.nama_urusan,
  k.id_bidang_urusan,
  k.kode_bidang_urusan,
  k.nama_bidang_urusan,
  k.id_sub_skpd,
  k.kode_sub_skpd,
  k.nama_sub_skpd,
  k.id_program,
  k.kode_program,
  k.nama_program,
  k.id_giat,
  k.kode_giat,
  k.nama_giat_kode_bl,
  k.nama_giat_nama_giat,
  k.nama_giat_thppos,
  k.nama_giat_gtlock,
  k.nama_giat_pagu_giat,
  k.nama_giat_rinci_giat,
  k.nama_giat_urlgiat,
  k.pagu_giat,
  k.rinci_giat,
  k.id_sub_giat,
  k.kode_sub_giat,
  k.nama_sub_giat_kode_bl,
  k.nama_sub_giat_kode_sbl,
  k.nama_sub_giat_nama_sub_giat,
  k.nama_sub_giat_thppos,
  k.nama_sub_giat_pagu,
  k.nama_sub_giat_rincian,
  k.nama_sub_giat_mst_lock,
  k.pagu,
  k.pagu2,
  k.pagu_indikatif,
  k.rincian,
  k.kode_bl,
  k.kode_sbl,
  k.urusan_locked,
  k.bidang_urusan_locked,
  k.program_locked,
  k.giat_locked,
  k.sub_giat_locked,
  k.kunci_bl,
  k.kunci_bl_rinci,
  k.user_created,
  k.created_date,
  k.created_time,
  k.user_updated,
  k.updated_date,
  k.updated_time,
  k.set_zona,
  k.usul_asmas,
  k.usul_kokab,
  k.usul_reses,
  k.action,
  k.status_giat,
  k.status_rincian,
  k.user1,
  k.user2,
  k.batasanpagu,
  k.pagumurni,
  k.realisasi,
  k.stat_usul,
  k.idprogram,
  k.idkegiatan,
  k.idsubkegiatan,
  pd.kode_skpd,
  pd.nama_skpd,
  i.idoutputbl,
  i.idsubkegiatan,
  i.outputteks,
  i.targetoutput,
  i.satuanoutput,
  s0.sasaran as sasprog,
  s1.sasaran as saskeg,
  s2.sasaran as sassubkeg
FROM
  public.data_sub_kegiatan k
  LEFT JOIN public.data_subkegiatan_indikator i ON (k.idsubkegiatan = i.idsubkegiatan)
  INNER JOIN public.data_pd pd ON (k.id_skpd = pd.id_skpd) 
  LEFT JOIN public.sasaran s0 ON (k.idprogram = s0.idpks) AND (s0.lvl=1)
  LEFT JOIN public.sasaran s1 ON (k.idkegiatan = s1.idpks) AND (s1.lvl=2)
  LEFT JOIN public.sasaran s2 ON (k.idsubkegiatan = s2.idpks) AND (s2.lvl=3)
  where k.id_sub_skpd=? and k.pagu>0;]]></xml-property>
        </oda-data-set>
