            <xml-property name="queryText"><![CDATA[SELECT 
  s.kode_sub_skpd,
    s.nama_sub_skpd,
    s.kode_urusan,
    s.nama_urusan,
    s.kode_bidang_urusan,
    s.nama_bidang_urusan,
    s.kode_program,
    s.nama_program,
    s.kode_giat,
    s.nama_giat_nama_giat,
    s.kode_sub_giat,
    s.nama_sub_giat_nama_sub_giat,
    s.idsubkegiatan,
    s.nama_sub_giat_rincian,
  sp.sasaran as sasaran_program,
  sk.sasaran as sasaran_kegiatan,
  ss.sasaran as sasaran_subkegiatan
FROM
  public.data_sub_kegiatan s
  LEFT JOIN public.sasaran sp ON (s.idprogram = sp.idpks) AND (sp.lvl=1)
  LEFT JOIN public.sasaran sk ON (s.idkegiatan = sk.idpks) AND (sk.lvl=2)
  LEFT JOIN public.sasaran ss ON (s.idsubkegiatan = ss.idpks) AND (ss.lvl=3)
  WHERE s.id_jadwal=1 AND s.kode_sub_skpd =? and  s.nama_sub_giat_rincian >0
  ORDER BY s.kode_program,s.kode_giat,s.kode_sub_giat;]]></xml-property>
        </oda-data-set>
    </data-sets>
