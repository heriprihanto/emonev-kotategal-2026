            <xml-property name="queryText"><![CDATA[SELECT 
  sub.id_subkegiatan,
  sub.id_kegiatan,
  sub.id_program,
  sub.tahun,
  sub.id_pd,
  sub.id_sub_pd,
  sub.id_bidang,
  sub.kd_urusana,
  sub.kd_bidanga,
  sub.kd_unita,
  sub.kd_suba,
  sub.kd_bidang_gab,
  sub.kd_unit_gab,
  sub.kd_sub_gab,
  sub.nm_bidang_gab,
  sub.nm_unit_gab,
  sub.nm_sub_unit_gab,
  sub.kd_urusan,
  sub.kd_bidang,
  sub.kd_program,
  sub.kd_kegiatan,
  sub.kd_sub_kegiatan,
  sub.kd_gab_urusan,
  sub.kd_gab_bidang,
  sub.kd_gab_prog,
  sub.kd_gab_keg,
  sub.kd_gab_sub_keg,
  sub.nm_urusan,
  sub.nm_bidang,
  sub.nm_program,
  sub.nm_kegiatan,
  sub.nm_sub_kegiatan,
  sub.nm_sumber,
  sub.id_ppk,
  sub.id_pptk,
  sub.id_personel,
  sub.pagu_akhir_renstra,
  sub.pagu_renstra,
  sub.pagu_renja,
  angg.total,
  pe.kd_tahap,
  pe.kd_sumber,
  pe.pagu_anggaran,
  pe.nomor_rup,
  pe.nomor_pekerjaan,
  pe.nama_pekerjaan,
  pe.jenis_paket,
  pe.jenis_belanja,
  pe.jenis_pengadaan,
  pe.metode,
  pe.volume,
  pe.lokasi,
  pe.tgl_mulai_pemilihan,
  pe.tgl_akhir_pemilihan,
  pe.tgl_mulai_pelaksanaan,
  pe.tgl_akhir_pelaksanaan,
  pe.tgl_buat,
  pe.user_buat,
  pe.jan,
  pe.feb,
  pe.mar,
  pe.apr,
  pe.mei,
  pe.jun,
  pe.jul,
  pe.agu,
  pe.sep,
  pe.okt,
  pe.nov,
  pe.des,
  pe.jan_f,
  pe.feb_f,
  pe.mar_f,
  pe.apr_f,
  pe.mei_f,
  pe.jun_f,
  pe.jul_f,
  pe.agu_f,
  pe.sep_f,
  pe.okt_f,
  pe.nov_f,
  pe.des_f,
  pe.nama_ppk,
  pe.nama_pptk,
  pe.nama_pokja,
  pe.nama_pphp,
  pe.hps,
  pe.nilai_kontrak,
  pe.sisa_anggaran,
  pe.realisasi,
  pe.nama_penyedia,
  pe.alamat_penyedia,
  pe.nama_direktur,
  pe.npwp_penyedia,
  pe.nomor_kontrak,
  pe.tgl_kontrak1,
  pe.tgl_kontrak2,
  pe.nomor_spmk,
  pe.tgl_spmk1,
  pe.tgl_spmk2,
  pe.tgl_adendum,
  pe.tgl_terima1,
  pe.tgl_terima2,
  pe.status,
  pe.ket_pekerjaan,
  pe.awal_pelaksanaan,
  pe.akhir_pelaksanaan,
  pe.awal_pemilihan,
  pe.akhir_pemilihan,
  pe.awal_kontrak,
  pe.akhir_kontrak,
  pe.anggaran1,
  pe.anggaran2,
  pe.anggaran3,
  pe.tipe_swa,
  pe.penyelenggara_swa,
  pr.bulan,
  pr.keuangan,
  pr.fisik,
  pr.masalah,
  pr.upaya,
  pr.keuangan_lalu,
  pr.fisik_lalu,
  kr.realisasi as realisasi_keuangan,
  kr.realisasi_lalu,
  kr.realisasi_total,
  ps1.nama as nama_ppkkeg,
  ps2.nama as nama_pptkkeg
FROM
  public.ta_subkegiatan sub
  INNER JOIN public.ta_subkegiatan_anggaran angg ON (sub.id_subkegiatan = angg.id_subkegiatan)
  LEFT JOIN public.ta_personel ps1 ON (sub.id_ppk = ps1.id_personel)
  LEFT JOIN public.ta_personel ps2 ON (sub.id_pptk = ps2.id_personel)
  LEFT JOIN public.ta_pekerjaan pe ON (sub.id_subkegiatan = pe.id_subkegiatan)
  LEFT JOIN (SELECT pr0.* FROM public.ta_pekerjaan_realisasi pr0 WHERE pr0.id_sub_pd=? AND pr0.bulan=?) pr ON (pe.id_pekerjaan = pr.id_pekerjaan)
  LEFT JOIN (SELECT kr0.* FROM public.ta_subkegiatan_realisasi kr0 WHERE kr0.id_sub_pd=? AND kr0.bulan=?) kr ON (sub.id_subkegiatan = kr.id_subkegiatan)
  WHERE sub.id_sub_pd=?;]]></xml-property>
        </oda-data-set>
    </data-sets>
