                    <text-property name="content"><![CDATA[<B><I>Dicetak dengan SIMLABA</I></B> at <value-of>new Date()</value-of> oleh <value-of>params["puser"]</value-of>&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; Hal - <value-of>pageNumber</value-of> -    ]]></text-property>
                </text>
