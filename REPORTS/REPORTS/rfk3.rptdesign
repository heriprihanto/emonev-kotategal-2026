            <xml-property name="queryText"><![CDATA[SELECT 
  s.id_subkegiatan,
  s.id_kegiatan,
  s.id_program,
  s.id_sub_pd,
  s.kd_sub_gab,
  s.nm_sub_unit_gab,
  s.kd_gab_prog,
  s.kd_gab_keg,s.kd_gab_sub_keg,
  s.nm_program,s.nm_kegiatan,s.nm_sub_kegiatan,
  p.*,
  m.nama_metode,
  r.*
FROM
  public.ta_subkegiatan s
  INNER JOIN public.ta_pekerjaan p ON (s.id_subkegiatan = p.id_subkegiatan)
  INNER JOIN public.ref_metode m ON (p.metode = m.id)
  LEFT JOIN (SELECT r0.* FROM public.ta_pekerjaan_realisasi r0 WHERE r0.bulan=?) r ON (p.id_pekerjaan=r.id_pekerjaan)  
  WHERE s.id_sub_pd=? AND p.nama_penyedia IS NOT NULL;]]></xml-property>
        </oda-data-set>
    </data-sets>
