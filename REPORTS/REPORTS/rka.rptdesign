            <xml-property name="queryText"><![CDATA[SELECT x.idsubkegiatan,
  x.kode_akun,
  x.nama_akun,
  x.subs_bl_teks_subs_asli,
  x.subs_bl_teks_kodesbl,
  x.subs_bl_teks_substeks,
  x.ket_bl_teks,
  x.id_standar_harga,
  x.nama_standar_harga_nama_komponen,
  x.nama_standar_harga_spek_komponen,
  string_agg(x.satuan,'') as satuan,
  string_agg(x.koefisien,'') as koefisien,
  sum(x.rincian) as rincian,
  sum(x.harga_satuan) as harga_satuan,
  string_agg(x.satuan_1,'') as satuan_1,
  string_agg(x.koefisien_1,'') as koefisien_1,
  sum(x.rincian_1) as rincian_1,
  sum(x.harga_satuan_1) as harga_satuan_1
   FROM
(SELECT 
  r1.idsubkegiatan,
  r1.kode_akun,
  r1.nama_akun,
  r1.subs_bl_teks_subs_asli,
  r1.subs_bl_teks_kodesbl,
  r1.subs_bl_teks_substeks,
  r1.ket_bl_teks,
  r1.id_standar_harga,
  r1.nama_standar_harga_nama_komponen,
  r1.nama_standar_harga_spek_komponen,
  r1.satuan::text as satuan,
  r1.koefisien,
  r1.rincian,
  r1.harga_satuan,
  '' as satuan_1,
  '' as koefisien_1,
  0 as rincian_1,
  0 as harga_satuan_1
FROM
  public.data_rka r1 WHERE r1.idsubkegiatan=? AND r1.id_jadwal=1
  UNION ALL
 SELECT
 r2.idsubkegiatan,
  r2.kode_akun,
  r2.nama_akun,
  r2.subs_bl_teks_subs_asli,
  r2.subs_bl_teks_kodesbl,
  r2.subs_bl_teks_substeks,
  r2.ket_bl_teks,
  r2.id_standar_harga,
  r2.nama_standar_harga_nama_komponen,
  r2.nama_standar_harga_spek_komponen,
  ''::text as satuan,
  '' as koefisien,
  0 as rincian,
  0 as harga_satuan,
  r2.satuan as satuan_1,
  r2.koefisien as koefisien_1,
  r2.rincian as rincian_1,
  r2.harga_satuan as harga_satuan_1
 FROM
  public.data_rka r2 WHERE r2.idsubkegiatan=? AND r2.id_jadwal > 1) x
  GROUP BY
  x.idsubkegiatan,
  x.kode_akun,
  x.nama_akun,
  x.subs_bl_teks_subs_asli,
  x.subs_bl_teks_kodesbl,
  x.subs_bl_teks_substeks,
  x.ket_bl_teks,
  x.id_standar_harga,
  x.nama_standar_harga_nama_komponen,
  x.nama_standar_harga_spek_komponen]]></xml-property>
        </oda-data-set>
