            <property name="leftMargin">0.25in</property>
            <property name="bottomMargin">0.2in</property>
            <property name="rightMargin">0.2in</property>
            <property name="height">13in</property>
            <property name="width">8.5in</property>
        </simple-master-page>
    </page-setup>
