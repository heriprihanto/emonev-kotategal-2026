            <xml-property name="queryText"><![CDATA[SELECT 
  r.id,
  r.idsubkegiatan,
  r.kode_akun,
  r.nama_akun,
  r.lokus_akun_teks,
  r.jenis_bl,
  r.is_paket,
  r.subs_bl_teks_subs_asli,
  r.subs_bl_teks_kodesbl,
  r.subs_bl_teks_substeks,
  r.ket_bl_teks,
  r.id_standar_harga,
  r.kode_standar_harga,
  r.nama_standar_harga_nama_komponen,
  r.nama_standar_harga_spek_komponen,
  r.satuan,
  r.spek,
  r.rincian,
  r.pajak,
  r.volume,
  r.harga_satuan,
  r.koefisien,
  r.vol_1,
  r.sat_1,
  r.vol_2,
  r.sat_2,
  r.vol_3,
  r.sat_3,
  r.vol_4,
  r.sat_4,
  r.rincian_murni,
  r.pajak_murni,
  r.volume_murni,
  r.harga_satuan_murni,
  r.koefisien_murni,
  r.totalpajak,
  r.pajakmurni,
  r.id_jadwal,
  s.kode_skpd,
  s.nama_skpd,
  s.id_urusan,
  s.kode_urusan,
  s.nama_urusan,
  s.id_bidang_urusan,
  s.kode_bidang_urusan,
  s.nama_bidang_urusan,
  s.id_sub_skpd,
  s.kode_sub_skpd,
  s.nama_sub_skpd,
  s.id_program,
  s.kode_program,
  s.nama_program,
  s.id_giat,
  s.kode_giat,
  s.nama_giat_kode_bl,
  s.nama_giat_nama_giat,
  s.kode_sub_giat,
  s.nama_sub_giat_nama_sub_giat
FROM
  public.data_rka r
  INNER JOIN public.data_sub_kegiatan s ON (r.idsubkegiatan = s.idsubkegiatan) WHERE r.rincian >0 AND s.idsubkegiatan =? AND r.id_jadwal=22072022;]]></xml-property>
        </oda-data-set>
    </data-sets>
