            <xml-property name="queryText"><![CDATA[SELECT 
  s.kode_akun_2,
  s.nama_akun_2,
  s.kode_akun_3,
  s.nama_akun_3,
  sum(s.total_harga) as total
FROM
  public.ta_subkegiatan_rincian s
WHERE s.id_sub_skpd=? and s.tahun=?
GROUP BY
s.kode_akun_2,
  s.nama_akun_2,
  s.kode_akun_3,
  s.nama_akun_3
  ORDER BY kode_akun_2,kode_akun_3
]]></xml-property>
