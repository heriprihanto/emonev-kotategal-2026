            <xml-property name="queryText"><![CDATA[SELECT 
  k.id_subkegiatan,
  k.id_kegiatan,
  k.id_program,
  k.tahun,
  k.id_pd,
  k.id_sub_pd,
  k.id_bidang,
  k.kd_urusana,
  k.kd_bidanga,
  k.kd_unita,
  k.kd_suba,
  k.kd_bidang_gab,
  k.kd_unit_gab,
  k.kd_sub_gab,
  k.nm_bidang_gab,
  k.nm_unit_gab,
  k.nm_sub_unit_gab,
  k.kd_urusan,
  k.kd_bidang,
  k.kd_program,
  k.kd_kegiatan,
  k.kd_sub_kegiatan,
  k.kd_gab_urusan,
  k.kd_gab_bidang,
  k.kd_gab_prog,
  k.kd_gab_keg,
  k.kd_gab_sub_keg,
  k.nm_urusan,
  k.nm_bidang,
  k.nm_program,
  k.nm_kegiatan,
  k.nm_sub_kegiatan,
  k.lokasi,
  k.nm_sumber,
  k.id_ppk,
  k.id_pptk,
  k.id_personel,
  k.pagu_akhir_renstra,
  k.pagu_renstra,
  k.pagu_renja,
  k.capaian_lalu,
  i.kd_tahap,
  i.no_id,
  i.tolak_ukur,
  i.target,
  i.satuan,
  a.total
FROM
  public.ta_subkegiatan k
  INNER JOIN public.ta_indikator_subkegiatan i ON (k.id_subkegiatan = i.id_subkegiatan)
  INNER JOIN public.ta_subkegiatan_anggaran a ON (k.id_subkegiatan = a.id_subkegiatan) 
   where k.id_sub_pd=?;]]></xml-property>
