            <xml-property name="queryText"><![CDATA[SELECT 
  r.id_sub_skpd,
  r.bp,
  r.bb,
  r.bh,
  r.bs,
  r.bmt,
  r.bpm,
  r.bg,
  r.bj,
  r.ba,
  r.btt,
  s.id_sub_pd,
  (r.bp+
  r.bb+
  r.bh+
  r.bs+
  r.bmt+
  r.bpm+
  r.bg+
  r.bj+
  r.ba+
  r.btt) as total,
  (r.bp+
  r.bb+
  r.bh+
  r.bs) as total1,
  ( r.bmt+
  r.bpm+
  r.bg+
  r.bj+
  r.ba) as total2
FROM
  sipd.sipd_rekap_per_rekening r
  INNER JOIN public.ref_sub_pd_sipd2 s ON (r.id_sub_skpd = s.id_sub_skpd)
  where s.id_sub_pd=?;]]></xml-property>
