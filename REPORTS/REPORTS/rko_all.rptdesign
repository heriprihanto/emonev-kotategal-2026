            <xml-property name="queryText"><![CDATA[SELECT 
  p.id_personel,
  p.nip,
  p.nama,
  p.jabatan,
  p.pangkat,
  p.golongan,
  p.level,
  p.id_atasan,
  p.eselon,
  p.eselon_a,
  p.tahun,
  p.id_sub_pd,
  p.kedudukan,
  k.kedudukan as ket_kedudukan,
  k.ket
FROM
  public.ta_personel p
  INNER JOIN public.ref_kedudukan k ON  (p.kedudukan = k.id)
  where p.id_sub_pd=? order by p.kedudukan asc;]]></xml-property>
