            <xml-property name="queryText"><![CDATA[SELECT 
    s.kode_sub_skpd,
    s.nama_sub_skpd,
    s.kode_urusan,
    s.nama_urusan,
    s.kode_bidang_urusan,
    s.nama_bidang_urusan,
    s.kode_program,
    s.nama_program,
    s.kode_giat,
    s.nama_giat_nama_giat,
    s.kode_sub_giat,
    s.nama_sub_giat_nama_sub_giat,
    s.idsubkegiatan,
    sum(case WHEN s.id_jadwal=1 THEN s.nama_sub_giat_rincian ELSE 0 END) AS rkpd,
    sum(case WHEN s.id_jadwal=22072022 THEN s.nama_sub_giat_rincian ELSE 0 END) AS kua,
    0::numeric as apbd
   FROM data_sub_kegiatan s WHERE s.kode_sub_skpd =? and  s.nama_sub_giat_rincian >0
  GROUP BY s.kode_sub_skpd,
    s.nama_sub_skpd,
    s.kode_urusan,
    s.nama_urusan,
    s.kode_bidang_urusan,
    s.nama_bidang_urusan,
    s.kode_program,
    s.nama_program,
    s.kode_giat,
    s.nama_giat_nama_giat,
    s.kode_sub_giat,
    s.nama_sub_giat_nama_sub_giat,
    s.idsubkegiatan 
    ORDER BY s.kode_program,s.kode_giat,s.kode_sub_giat;]]></xml-property>
        </oda-data-set>
    </data-sets>
