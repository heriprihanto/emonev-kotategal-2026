            <xml-property name="queryText"><![CDATA[SELECT x.* FROM
(SELECT 
  r.t1_kode,
  r.t2_kode,
  r.t1_nama,
  r.t2_nama,
  r.kat_dak,
  r.t1,r.t2,r.kd_jenis,
  SUM(r.pagu) as pagu,
  SUM(r.real_k) as real_k,
  avg(r.real_fisik) as real_fisik
FROM
  public.dak_detail_rincian r where r.tw=?
  GROUP BY
  r.t1_kode,
  r.t2_kode,
  r.t1_nama,
  r.t2_nama,r.kat_dak,r.t1,r.t2,r.kd_jenis)x ORDER BY x.t1,x.t2
  ]]></xml-property>
