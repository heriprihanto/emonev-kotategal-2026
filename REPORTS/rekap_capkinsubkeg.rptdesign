            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT x.kode as kodeopd, x.nama_pd as namaopd, o.*, predikat_pko(o.real_subkeg) as predikatpko FROM public.rpt_rekap_kinerja_opd_tw(?,?) o JOIN (SELECT c.* from ta_opd c where c.is_pd=1) x
ON (o.id_pd = x.id_pd) order by o.kode asc]]></xml-property>
        </oda-data-set>
