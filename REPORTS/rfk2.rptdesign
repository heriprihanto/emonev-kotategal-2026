                    <property name="nativeDataType">2</property>
                </structure>
                <structure>
                    <property name="position">65</property>
                    <property name="name">r_fi_12</property>
                    <property name="nativeName">r_fi_12</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">2</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT CONCAT(k.kd_urusan, '.', k.kd_bidang, '.', k.kd_unit, '.', k.kd_sub) AS
  kd_sub_unit_gab,
       su.nm_sub_unit,
       CONCAT(prog.kd_urusan1,'.',  prog.kd_bidang1,'.',  prog.kd_prog) AS kd_prog_gab,
       prog.ket_program,
       CONCAT(prog.kd_urusan1,'.',  prog.kd_bidang1,'.',  prog.kd_prog,'.',  k.kd_keg) AS
         kd_keg_gab,
       k.ket_kegiatan,
       bel.total_anggaran,
       real_keu.r_keu_1,
       (real_keu.r_keu_1+real_keu.r_keu_2) AS r_keu_2,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3) AS r_keu_3,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4) AS r_keu_4,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5) AS r_keu_5,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5+real_keu.r_keu_6) AS r_keu_6,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5+real_keu.r_keu_6+real_keu.r_keu_7) AS r_keu_7,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5+real_keu.r_keu_6+real_keu.r_keu_7+real_keu.r_keu_8) AS r_keu_8,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5+real_keu.r_keu_6+real_keu.r_keu_7+real_keu.r_keu_8+real_keu.r_keu_9) AS r_keu_9,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5+real_keu.r_keu_6+real_keu.r_keu_7+real_keu.r_keu_8+real_keu.r_keu_9+real_keu.r_keu_10) AS r_keu_10,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5+real_keu.r_keu_6+real_keu.r_keu_7+real_keu.r_keu_8+real_keu.r_keu_9+real_keu.r_keu_10+real_keu.r_keu_11) AS r_keu_11,
       (real_keu.r_keu_1+real_keu.r_keu_2+real_keu.r_keu_3+real_keu.r_keu_4+real_keu.r_keu_5+real_keu.r_keu_6+real_keu.r_keu_7+real_keu.r_keu_8+real_keu.r_keu_9+real_keu.r_keu_10+real_keu.r_keu_11+real_keu.r_keu_12) AS r_keu_12,
       xpr.*
FROM public.lab_ta_kegiatan k
     INNER JOIN public.lab_ref_sub_unit su ON (su.kd_urusan = k.kd_urusan) AND (
       su.kd_bidang = k.kd_bidang) AND (su.kd_unit = k.kd_unit) AND (su.kd_sub =
       k.kd_sub)
     INNER JOIN public.lab_ta_program prog ON (prog.tahun = k.tahun) AND (
       prog.kd_urusan = k.kd_urusan) AND (prog.kd_bidang = k.kd_bidang) AND (
       prog.kd_unit = k.kd_unit) AND (prog.kd_sub = k.kd_sub) AND (prog.kd_prog
       = k.kd_prog) AND (prog.id_prog = k.id_prog)
     INNER JOIN 
              (
                SELECT b.tahun,
                       b.kd_urusan,
                       b.kd_bidang,
                       b.kd_unit,
                       b.kd_sub,
                       b.kd_prog,
                       b.id_prog,
                       b.kd_keg,
                       SUM(b.anggaran) AS total_anggaran
                FROM lab_ta_belanja b
                WHERE b.kd_perubahan = ?
                GROUP BY b.tahun,
                         b.kd_urusan,
                         b.kd_bidang,
                         b.kd_unit,
                         b.kd_sub,
                         b.kd_prog,
                         b.id_prog,
                         b.kd_keg
              ) bel ON (k.tahun = bel.tahun) AND (k.kd_urusan = bel.kd_urusan)
                AND (k.kd_bidang = bel.kd_bidang) AND (k.kd_unit = bel.kd_unit)
                AND (k.kd_sub = bel.kd_sub) AND (k.kd_prog = bel.kd_prog) AND (
                k.id_prog = bel.id_prog) AND (k.kd_keg = bel.kd_keg) 
     
     LEFT JOIN 
       (
         SELECT rk.tahun,
                rk.kd_urusan,
                rk.kd_bidang,
                rk.kd_unit,
                rk.kd_sub,
                rk.kd_prog,
                rk.id_prog,
                rk.kd_keg,
                SUM(case
                      when rk.bulan = 1 THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_1,
                SUM(case
                      when rk.bulan = 2  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_2,
                SUM(case
                      when rk.bulan = 3  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_3,
                SUM(case
                      when rk.bulan = 4  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_4,
                SUM(case
                      when rk.bulan = 5  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_5,
                SUM(case
                      when rk.bulan = 6  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_6,
                SUM(case
                      when rk.bulan = 7  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_7,
                SUM(case
                      when rk.bulan = 8  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_8,
                SUM(case
                      when rk.bulan = 9  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_9,
                SUM(case
                      when rk.bulan = 10  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_10,
                SUM(case
                      when rk.bulan = 11  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_11,
                SUM(case
                      when rk.bulan = 12  THEN rk.realisasi
                      ELSE 0
                    END) AS r_keu_12
         FROM public.lab_ta_belanja_realisasi rk
         GROUP BY rk.tahun,
                  rk.kd_urusan,
                  rk.kd_bidang,
                  rk.kd_unit,
                  rk.kd_sub,
                  rk.kd_prog,
                  rk.id_prog,
                  rk.kd_keg
       ) real_keu ON k.tahun = real_keu.tahun AND k.kd_urusan =
         real_keu.kd_urusan AND k.kd_bidang = real_keu.kd_bidang AND k.kd_unit =
         real_keu.kd_unit AND k.kd_sub = real_keu.kd_sub AND k.kd_prog =
         real_keu.kd_prog AND k.id_prog = real_keu.id_prog AND k.kd_keg =
         real_keu.kd_keg
      
     INNER JOIN 
     (
       SELECT p.tahun,
              p.kd_urusan,
              p.kd_bidang,
              p.kd_unit,
              p.kd_sub,
              p.kd_prog,
              p.id_prog,
              p.kd_keg,
              p.kd_perubahan,
              p.nomor_pekerjaan,
              AVG(p.jan) AS targ_keu_1,
              AVG(p.jan + p.feb) AS targ_keu_2,
              AVG(p.jan + p.feb + p.mar) AS targ_keu_3,
              AVG(p.jan + p.feb + p.mar + p.apr) AS targ_keu_4,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei) AS targ_keu_5,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei + p.jun) AS targ_keu_6,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei + p.jun + p.jul) AS
                targ_keu_7,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei + p.jun + p.jul + p.agu)
                AS targ_keu_8,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei + p.jun + p.jul + p.agu
                + p.sep) AS targ_keu_9,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei + p.jun + p.jul + p.agu
                + p.sep + p.okt) AS targ_keu_10,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei + p.jun + p.jul + p.agu
                + p.sep + p.okt + p.nov) AS targ_keu_11,
              AVG(p.jan + p.feb + p.mar + p.apr + p.mei + p.jun + p.jul + p.agu
                + p.sep + p.okt + p.nov + p.des) AS targ_keu_12,
              AVG(p.jan_f) AS targ_fi_1,
              AVG(p.feb_f) AS targ_fi_2,
              AVG(p.mar_f) AS targ_fi_3,
              AVG(p.apr_f) AS targ_fi_4,
              AVG(p.mei_f) AS targ_fi_5,
              AVG(p.jun_f) AS targ_fi_6,
              AVG(p.jul_f) AS targ_fi_7,
              AVG(p.agu_f) AS targ_fi_8,
              AVG(p.sep_f) AS targ_fi_9,
              AVG(p.okt_f) AS targ_fi_10,
              AVG(p.nov_f) AS targ_fi_11,
              AVG(p.des_f) AS targ_fi_12,
              SUM(case
                    when pr.bulan = 1 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_1,
              SUM(case
                    when pr.bulan = 2 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_2,
              SUM(case
                    when pr.bulan = 3 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_3,
              SUM(case
                    when pr.bulan = 4 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_4,
              SUM(case
                    when pr.bulan = 5 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_5,
              SUM(case
                    when pr.bulan = 6 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_6,
              SUM(case
                    when pr.bulan = 7 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_7,
              SUM(case
                    when pr.bulan = 8 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_8,
              SUM(case
                    when pr.bulan = 9 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_9,
              SUM(case
                    when pr.bulan = 10 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_10,
              SUM(case
                    when pr.bulan = 11 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_11,
              SUM(case
                    when pr.bulan = 12 THEN pr.fisik
                    ELSE 0
                  END) AS r_fi_12
       FROM public.lab_ta_pekerjaan p
            INNER JOIN public.lab_ta_pekerjaan_realisasi pr ON (p.tahun =
              pr.tahun) AND (p.kd_urusan = pr.kd_urusan) AND (p.kd_bidang =
              pr.kd_bidang) AND (p.kd_unit = pr.kd_unit) AND (p.kd_sub =
              pr.kd_sub) AND (p.kd_prog = pr.kd_prog) AND (p.id_prog =
              pr.id_prog) AND (p.kd_keg = pr.kd_keg) AND (p.nomor_pekerjaan =
              pr.nomor_pekerjaan)
       WHERE 
       p.kd_perubahan = ? AND
       p.tahun = ? AND
       p.kd_urusan = ? AND
             p.kd_bidang = ? AND
             p.kd_unit = ? AND
             p.kd_sub = ?
       GROUP BY p.tahun,
                p.kd_urusan,
                p.kd_bidang,
                p.kd_unit,
                p.kd_sub,
                p.kd_prog,
                p.id_prog,
                p.kd_keg,
                p.kd_perubahan,
                p.nomor_pekerjaan
     ) xpr ON (xpr.tahun = k.tahun) AND (xpr.kd_urusan = k.kd_urusan) AND (
       xpr.kd_bidang = k.kd_bidang) AND (xpr.kd_unit = k.kd_unit) AND (
       xpr.kd_sub = k.kd_sub) AND (xpr.kd_prog = k.kd_prog) AND (xpr.id_prog =
       k.id_prog) AND (xpr.kd_keg = k.kd_keg) AND (xpr.kd_perubahan =
       k.kd_perubahan)
ORDER BY 
         k.kd_prog,
         k.kd_keg;]]></xml-property>
            <xml-property name="designerValues"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<model:DesignValues xmlns:design="http://www.eclipse.org/datatools/connectivity/oda/design" xmlns:model="http://www.eclipse.org/birt/report/model/adapter/odaModel">
  <Version>2.0</Version>
  <design:ResultSets derivedMetaData="true">
    <design:resultSetDefinitions>
      <design:resultSetColumns>
