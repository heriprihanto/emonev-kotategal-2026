            <xml-property name="queryText"><![CDATA[SELECT 
  k.idsubkegiatan,
  k.idkegiatan,
  k.idprogram,
  k.tahun,
  k.id_sub_pd,
  o.nama_pd,
  k.kode_program,k.kode_kegiatan,k.kode_sub_kegiatan,
  k.nm_program,k.nm_kegiatan,k.nm_sub_kegiatan,
  k.lokasi,
  k.nm_sumber,
  k.id_ppk ,
  k.id_pptk,
  k.id_personel,
  k.pagu_akhir_renstra,
  k.pagu_renstra,
  k.pagu_renja,
  p.id,
  p.tahun,
  p.id_sub_pd,
  p.kd_tahap,
  p.kd_sumber,
  p.pagu_anggaran,
  p.nomor_rup,
  p.nomor_pekerjaan,
  p.nama_pekerjaan,
  p.jenis_paket,
  p.jenis_belanja,
  p.jenis_pengadaan,
  p.metode,
  '' as ket_metode,
  p.volume,
  p.lokasi,
  p.tgl_mulai_pemilihan,
  p.tgl_akhir_pemilihan,
  p.tgl_mulai_pelaksanaan,
  p.tgl_akhir_pelaksanaan,
  p.tgl_buat,
  p.user_buat,
  p.jan,
  p.feb,
  p.mar,
  p.apr,
  p.mei,
  p.jun,
  p.jul,
  p.agu,
  p.sep,
  p.okt,
  p.nov,
  p.des,
  p.jan_f,
  p.feb_f,
  p.mar_f,
  p.apr_f,
  p.mei_f,
  p.jun_f,
  p.jul_f,
  p.agu_f,
  p.sep_f,
  p.okt_f,
  p.nov_f,
  p.des_f,
  p.nama_ppk,
  p.nama_pptk,
  p.nama_pokja,
  p.nama_pphp,
  p.hps,
  p.nilai_kontrak,
  p.sisa_anggaran,
  p.realisasi,
  p.nama_penyedia,
  p.alamat_penyedia,
  p.nama_direktur,
  p.npwp_penyedia,
  p.nomor_kontrak,
  p.tgl_kontrak1,
  p.tgl_kontrak2,
  p.nomor_spmk,
  p.tgl_spmk1,
  p.tgl_spmk2,
  p.tgl_adendum,
  p.tgl_terima1,
  p.tgl_terima2,
  p.status,
  p.ket_pekerjaan,
  p.awal_pelaksanaan,
  p.akhir_pelaksanaan,
  p.awal_pemilihan,
  p.akhir_pemilihan,
  p.awal_kontrak,
  p.akhir_kontrak,
  p.anggaran1,
  p.anggaran2,
  p.anggaran3,
  p.tipe_swa,
  p.penyelenggara_swa,
  k.anggaran as total
FROM
  public.ta_renja_subkegiatan k
  INNER JOIN ta_opd o ON (k.id_sub_pd = o.id_sub_pd)
  INNER JOIN public.ta_pekerjaan p ON (k.idsubkegiatan = p.id_subkegiatan )
  where k.id_sub_pd=?;]]></xml-property>
