            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT 
  sk.kode_program,
  sk.kode_kegiatan,
  sk.kode_sub_kegiatan,
  sk.nm_program,
  sk.nm_kegiatan,
  sk.nm_sub_kegiatan,
  sk.anggaran,
  i.kode,
  i.tolok_ukur,
  i.satuan,
  i.target
FROM
  public.ta_renja_subkegiatan sk
  INNER JOIN public.renja_indikator i ON (sk.idsubkegiatan = i.id_parent)
  AND (sk.id_sub_pd = i.id_sub_pd)
  AND (sk.tahun = i.tahun) 
  where i.lvl=7 and sk.tahun=? and sk.id_sub_pd=?
]]></xml-property>
