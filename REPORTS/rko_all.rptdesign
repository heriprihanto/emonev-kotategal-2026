            <xml-property name="queryText"><![CDATA[SELECT 
  sk.kode_sub_kegiatan,
  sk.nm_sub_kegiatan,
  p.nip,
  p.nama,
  p.jabatan
FROM
  public.ta_renja_subkegiatan sk
  RIGHT JOIN public.ta_personel p ON (sk.id_pptk = p.id)
  where sk.id_sub_pd=? and sk.tahun=?]]></xml-property>
